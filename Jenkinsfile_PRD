pipeline {
    agent any

    environment {
        IMAGE_NAME = 'fcfb-website-prd'
        CONTAINER_NAME = 'FCFB-Website-PRD'
        DOCKERFILE = 'Dockerfile_PRD'
        CLIENT_ID = credentials('DISCORD_CLIENT_ID')
        CLIENT_SECRET = credentials('DISCORD_CLIENT_SECRET')
        GITHUB_PAT = credentials('Github PAT')
    }

    stages {
        stage('Checkout') {
            steps {
                echo 'Checking out the FCFB Website repository...'
                checkout scm
            }
        }

        stage('Bump Version & Tag') {
            steps {
                script {
                    def latestTag = sh(
                        script: "git describe --tags --abbrev=0 2>/dev/null || echo 'v0.0.0'",
                        returnStdout: true
                    ).trim()
                    def version = latestTag.replaceFirst(/^v/, '')
                    def parts   = version.tokenize('.')
                    def major   = parts[0].toInteger()
                    def minor   = parts[1].toInteger()
                    def patch   = parts[2].toInteger()

                    def msg = sh(script: 'git log -1 --pretty=%B', returnStdout: true).trim()
                    if (msg.contains('[major]')) {
                        major++; minor = 0; patch = 0
                    } else if (msg.contains('[minor]')) {
                        minor++; patch = 0
                    } else {
                        patch++
                    }

                    def newVersion = "v${major}.${minor}.${patch}"
                    sh """
                        git config user.email "jenkins@boxscore.build"
                        git config user.name  "Jenkins"
                        git tag -a ${newVersion} -m "Auto-release ${newVersion} [build ${env.BUILD_NUMBER}]"
                        git push https://${env.GITHUB_PAT_USR}:${env.GITHUB_PAT_PSW}@github.com/\$(git remote get-url origin | sed 's|.*github.com[:/]||') ${newVersion}
                    """
                    env.VERSION = newVersion
                    currentBuild.description = "Version: ${newVersion}"
                    currentBuild.displayName = "Build #${env.BUILD_NUMBER} - ${newVersion}"
                }
            }
        }


        stage('Generate .env File') {
            steps {
                script {
                    echo 'Generating .env file...'
                    sh """
                        cat <<EOF > .env
                        VITE_CLIENT_ID=${CLIENT_ID}
                        VITE_CLIENT_SECRET=${CLIENT_SECRET}
                        VITE_BASE_URL=https://api.fakecollegefootball.com/api/v1/arceus/discord/redirect
                        VITE_API_BASE_URL=https://api.fakecollegefootball.com/api/v1/arceus
                        VITE_API_URL=https://api.fakecollegefootball.com
                        EOF
                    """
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                echo 'Building Docker image for FCFB Website (old container still running)...'
                sh """
                    docker build -f ${DOCKERFILE} -t ${IMAGE_NAME}:new .
                """
            }
        }

        stage('Swap Container') {
            steps {
                script {
                    echo 'Stopping old container and starting new one...'
                    sh """
                        docker stop ${CONTAINER_NAME} || echo "No running container found."
                        docker rm ${CONTAINER_NAME} || echo "No container to remove."
                        docker tag ${IMAGE_NAME}:new ${IMAGE_NAME}:latest
                        docker run -d --name ${CONTAINER_NAME} \
                            --restart unless-stopped \
                            --memory=512m \
                            -v /var/images:/app/images \
                            -p 462:462 \
                            --env-file .env \
                            ${IMAGE_NAME}:latest
                        docker rmi ${IMAGE_NAME}:new || true
                    """
                }
            }
        }

        stage('Health Check') {
            steps {
                script {
                    sleep(time: 10, unit: 'SECONDS')
                    def healthy = false
                    def attempts = 0
                    def maxAttempts = 24
                    while (!healthy && attempts < maxAttempts) {
                        attempts++
                        try {
                            def status = sh(
                                script: "docker exec ${env.CONTAINER_NAME} wget -q -O /dev/null http://127.0.0.1:462/ && echo OK || echo FAIL",
                                returnStdout: true
                            ).trim()
                            if (status == 'OK') {
                                healthy = true
                                echo "Container health OK (attempt ${attempts})"
                            }
                        } catch (e) {
                            // not ready yet
                        }
                        if (!healthy) {
                            echo "Waiting for health check... attempt ${attempts}/${maxAttempts}"
                            sleep 5
                        }
                    }
                    if (!healthy) {
                        sh "docker logs ${env.CONTAINER_NAME} --tail=80"
                        error('FCFB Website PRD container failed health check after deploy')
                    }
                }
            }
        }

        stage('Cleanup') {
            steps {
                script {
                    echo 'Cleaning up sensitive files...'
                    sh 'rm -f .env'
                }
            }
        }

        stage('Cleanup Docker System') {
            steps {
                script {
                    echo 'Pruning unused Docker resources...'
                    sh 'docker system prune -f'
                }
            }
        }
    }

    post {
        success {
            echo 'FCFB Website deployed successfully!'
        }
        failure {
            echo 'FCFB Website deployment failed.'
            sh 'rm -f .env || true'
        }
    }
}
