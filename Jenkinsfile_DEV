pipeline {
    agent any

    environment {
        IMAGE_NAME = 'fcfb-website-dev'
        CONTAINER_NAME = 'FCFB-Website-DEV'
        DOCKERFILE = 'Dockerfile_DEV'
        CLIENT_ID = credentials('CLIENT_ID_CREDENTIALS_ID')
        CLIENT_SECRET = credentials('CLIENT_SECRET_CREDENTIALS_ID')
    }

    stages {
        stage('Checkout') {
            steps {
                echo 'Checking out the FCFB Website repository...'
                checkout scm
            }
        }

        stage('Get Version') {
            steps {
                script {
                    def latestTag = sh(
                        script: "git describe --tags --abbrev=0 --match 'v*' 2>/dev/null || echo 'v0.0.0'",
                        returnStdout: true
                    ).trim()
                    env.VERSION = latestTag
                    currentBuild.description = "Version: ${latestTag}-dev"
                    currentBuild.displayName = "Build #${env.BUILD_NUMBER} - ${latestTag}-dev"
                }
            }
        }

        stage('Generate .env File') {
            steps {
                script {
                    echo 'Generating .env file...'
                    sh """
                        cat <<EOF > .env
                        REACT_APP_CLIENT_ID=${CLIENT_ID}
                        REACT_APP_CLIENT_SECRET=${CLIENT_SECRET}
                        REACT_APP_BASE_URL=https://dev.api.fakecollegefootball.com/api/v1/arceus/discord/redirect
                        REACT_APP_API_BASE_URL=https://dev.api.fakecollegefootball.com/api/v1/arceus
                        EOF
                    """
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                echo 'Building Docker image for FCFB Website (old container still running)...'
                sh """
                    docker build --no-cache -f ${DOCKERFILE} -t ${IMAGE_NAME}:new .
                """
            }
        }

        stage('Swap Container') {
            steps {
                script {
                    echo 'Stopping old container and starting new one...'
                    sh """
                        docker stop ${CONTAINER_NAME} || echo "No running container found."
                        docker rm ${CONTAINER_NAME} || echo "No container to remove."
                        docker tag ${IMAGE_NAME}:new ${IMAGE_NAME}:latest
                        docker run -d --name ${CONTAINER_NAME} \
                            -v /var/images:/app/images \
                            -p 462:462 \
                            --env-file .env \
                            ${IMAGE_NAME}:latest
                        docker rmi ${IMAGE_NAME}:new || true
                    """
                }
            }
        }

        stage('Health Check') {
            steps {
                script {
                    sleep(time: 10, unit: 'SECONDS')
                    def healthy = false
                    def attempts = 0
                    def maxAttempts = 24
                    while (!healthy && attempts < maxAttempts) {
                        attempts++
                        try {
                            def status = sh(
                                script: "docker exec ${env.CONTAINER_NAME} wget -q -O /dev/null http://127.0.0.1:461/ && echo OK || echo FAIL",
                                returnStdout: true
                            ).trim()
                            if (status == 'OK') {
                                healthy = true
                                echo "Container health OK (attempt ${attempts})"
                            }
                        } catch (e) {
                            // not ready yet
                        }
                        if (!healthy) {
                            echo "Waiting for health check... attempt ${attempts}/${maxAttempts}"
                            sleep 5
                        }
                    }
                    if (!healthy) {
                        sh "docker logs ${env.CONTAINER_NAME} --tail=80"
                        error('FCFB Website DEV container failed health check after deploy')
                    }
                }
            }
        }

        stage('Cleanup') {
            steps {
                script {
                    echo 'Cleaning up sensitive files...'
                    sh 'rm -f .env'
                }
            }
        }

        stage('Cleanup Docker System') {
            steps {
                script {
                    echo 'Pruning unused Docker resources...'
                    sh 'docker system prune -f'
                }
            }
        }
    }

    post {
        success {
            echo 'FCFB Website deployed successfully!'
        }
        failure {
            echo 'FCFB Website deployment failed.'
            sh 'rm -f .env || true'
        }
    }
}
